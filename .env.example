# GURAH — variables de entorno (modo real). Sin estas claves, todo funciona en MODO DEMO.
# Copia a .env y rellena. NUNCA subas .env al repositorio.

# Sitio
PUBLIC_SITE_URL=https://gurah.netlify.app
WEB_DISCOUNT_PCT=10

# Pagos (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email transaccional (Brevo)
BREVO_API_KEY=
EMAIL_FROM=reservas@gurah.com
ADMIN_EMAIL=info.venmon@gmail.com

# IA (reseñas / asistente) — Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Facturación TicketBAI / Batuz (Bizkaia) — [PENDIENTE CLIENTE]
TBAI_NIF=
TBAI_ENV=pruebas
# (firma XAdES real: certificado del emisor, se añade en producción)

# Panel
PANEL_PASSWORD=
SESSION_SECRET=

# WhatsApp (asistente) — opcional
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
