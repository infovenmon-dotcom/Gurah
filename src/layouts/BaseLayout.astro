---
/**
 * BaseLayout.astro — Shell común, tematizado por la capa de tema (src/lib/theme.ts).
 * Paleta, tipografías y marca provienen del tema activo → framework re-tematizable.
 */
import { activeTheme as t } from '../lib/theme';

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const {
  title = 'GURAH Boutique Apartments · Bakio, Bizkaia',
  description = 'Apartamentos boutique en Bakio, a 3 km de San Juan de Gaztelugatxe. Piscina, pet-friendly, reserva directa con el mejor precio.',
  lang = 'es',
} = Astro.props;

// Tokens de color + tipografías inyectados desde el tema activo.
const rootVars = `:root{` +
  `--verde:${t.palette.verde};--verde2:${t.palette.verde2};--salvia:${t.palette.salvia};` +
  `--arena:${t.palette.arena};--crema:${t.palette.crema};--tinta:${t.palette.tinta};` +
  `--gris:${t.palette.gris};--linea:${t.palette.linea};--dorado:${t.palette.dorado};` +
  `--serif:${t.fonts.serif};--sans:${t.fonts.sans};}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- Tipografías de marca: DM Serif Display (titulares) + Poppins (texto). En producción
         las carga el navegador; en el sandbox sin red se usan las fuentes de reserva. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {t.fonts.googleHref && <link href={t.fonts.googleHref} rel="stylesheet" />}
    <!-- Tokens de color + tipografías del tema activo -->
    <style is:global set:html={rootVars}></style>
    <style is:global>
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: var(--sans);
        font-weight: 300;
        color: var(--tinta);
        background: var(--crema);
        line-height: 1.6;
      }
      h1, h2, h3, .serif { font-family: var(--serif); font-weight: 400; }
      .sans { font-family: var(--sans); }
      a { color: var(--verde); }
      .container { max-width: 1120px; margin: 0 auto; padding: 0 20px; }
      .btn {
        display: inline-block; border: 0; border-radius: 8px; cursor: pointer;
        padding: 13px 26px; font-size: 14px; font-weight: 500; letter-spacing: .04em;
        font-family: var(--sans);
        background: var(--verde); color: #fff; text-decoration: none; transition: background .2s;
      }
      .btn:hover { background: var(--verde2); }
      .btn.ghost { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,.7); }
      header.site {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 24px; position: sticky; top: 0; background: rgba(246,241,232,.9);
        backdrop-filter: blur(10px); border-bottom: 1px solid var(--linea); z-index: 20;
      }
      .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
      .brand svg { color: var(--tinta); }
      .brand b { font-family: var(--serif); font-weight: 400; font-size: 24px; letter-spacing: .22em; color: var(--tinta); line-height: 1; }
      .brand small { color: var(--gris); font-size: 10px; letter-spacing: .28em; text-transform: uppercase; }
      footer.site { background: var(--tinta); color: #cfc9bc; margin-top: 60px; padding: 46px 0; font-family: var(--sans); font-size: 14px; }
      footer.site a { color: #fff; }
    </style>
  </head>
  <body>
    <header class="site">
      <a class="brand" href="/">
        <!-- Marca GURAH: G + ola dentro de un círculo (según board de identidad) -->
        <svg width="38" height="38" viewBox="0 0 48 48" aria-hidden="true" fill="none">
          <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.3" />
          <path d="M33 16.5 A11 11 0 1 0 34.5 31 L34.5 24 L27 24" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
          <path d="M14.5 27.5 q4 -4 8 0 t 8 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          <path d="M15.5 31.5 q4 -3.5 8 0 t 8 0" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.55" />
        </svg>
        <span><b>{t.brand.name}</b><br /><small>{t.brand.subtitle}</small></span>
      </a>
      <nav class="sans" style="display:flex;gap:18px;align-items:center">
        <a href="/#apartamentos" style="text-decoration:none;color:var(--tinta)">Apartamentos</a>
        <a href="/#experiencia" style="text-decoration:none;color:var(--tinta)">Entorno</a>
        <a class="btn" href="/#apartamentos">Reservar</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site">
      <div class="container" style="display:flex;flex-wrap:wrap;gap:30px;justify-content:space-between">
        <div>
          <b class="serif" style="font-size:22px;letter-spacing:.22em">{t.brand.name}</b>
          <p style="letter-spacing:.18em;font-size:11px;text-transform:uppercase;color:#a49d8f;margin:4px 0 10px">{t.brand.tagline}</p>
          <p>Apartamentos boutique · Bakio, Bizkaia<br />A 3 km de San Juan de Gaztelugatxe.</p>
        </div>
        <div>
          <p><strong>Reserva directa</strong><br />El mejor precio, sin comisiones de plataformas.</p>
          <p class="muted" style="color:#9fb0a8">Un proyecto de Venmon.</p>
        </div>
        <div>
          <a href="/privacidad">Privacidad</a> · <a href="/panel/login">Panel</a>
        </div>
      </div>
    </footer>
  </body>
</html>
