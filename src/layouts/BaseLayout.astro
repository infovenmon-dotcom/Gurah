---
/**
 * BaseLayout.astro — Shell común, tematizado por la capa de tema (src/lib/theme.ts).
 * Paleta, tipografías y marca provienen del tema activo → framework re-tematizable.
 */
import { getTheme } from '../lib/theme';
import { getLang, localeOf, LOCALES, langHref, t as tr } from '../lib/i18n';
const t = getTheme(Astro.url);

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const {
  title = 'GURAH Boutique Apartments · Bakio, Bizkaia',
  description = 'Apartamentos boutique en Bakio, a 10 minutos de San Juan de Gaztelugatxe y 30 de Bilbao. Piscina, pet-friendly, reserva directa con el mejor precio.',
} = Astro.props;

// Idioma activo (query ?lang → cookie → Accept-Language → es). Se persiste en cookie.
const lang = Astro.props.lang
  ? (Astro.props.lang as any)
  : getLang(Astro.url, Astro.cookies, Astro.request.headers.get('accept-language'));
const activeLocale = localeOf(lang);

// Ikurriña (bandera vasca) en SVG: el emoji con secuencia de etiqueta no lo pinta
// la mayoría de sistemas (sale como «?»), así que la dibujamos.
const ikurrina =
  '<svg viewBox="0 0 30 20" width="17" height="12" style="border-radius:2px;display:block" aria-hidden="true">' +
  '<rect width="30" height="20" fill="#D52B1E"/>' +
  '<path d="M0 0 L30 20 M30 0 L0 20" stroke="#009B48" stroke-width="4"/>' +
  '<path d="M15 0 V20 M0 10 H30" stroke="#fff" stroke-width="4"/></svg>';

// Tokens de color + tipografías inyectados desde el tema activo.
const rootVars = `:root{` +
  `--verde:${t.palette.verde};--verde2:${t.palette.verde2};--salvia:${t.palette.salvia};` +
  `--arena:${t.palette.arena};--crema:${t.palette.crema};--tinta:${t.palette.tinta};` +
  `--gris:${t.palette.gris};--linea:${t.palette.linea};--dorado:${t.palette.dorado};` +
  `--serif:${t.fonts.serif};--sans:${t.fonts.sans};}`;
---

<!doctype html>
<html lang={activeLocale.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <!-- SEO multi-idioma: alternativas hreflang para los 10 idiomas -->
    {LOCALES.map((l) => (
      <link rel="alternate" hreflang={l.htmlLang} href={langHref(Astro.url, l.code)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={Astro.url.pathname} />
    <!-- Tipografías de marca: DM Serif Display (titulares) + Poppins (texto). En producción
         las carga el navegador; en el sandbox sin red se usan las fuentes de reserva. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {t.fonts.googleHref && <link href={t.fonts.googleHref} rel="stylesheet" />}
    <!-- Tokens de color + tipografías del tema activo -->
    <style is:global set:html={rootVars}></style>
    <style is:global>
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; overflow-x: hidden; }
      body {
        margin: 0;
        font-family: var(--sans);
        font-weight: 300;
        color: var(--tinta);
        background: var(--crema);
        line-height: 1.6;
        overflow-x: hidden;
        max-width: 100%;
      }
      img, video { max-width: 100%; }
      h1, h2, h3, .serif { font-family: var(--serif); font-weight: 400; }
      .sans { font-family: var(--sans); }
      a { color: var(--verde); }
      .container { max-width: 1120px; margin: 0 auto; padding: 0 20px; }
      .btn {
        display: inline-block; border: 0; border-radius: 8px; cursor: pointer;
        padding: 13px 26px; font-size: 14px; font-weight: 500; letter-spacing: .04em;
        font-family: var(--sans);
        background: var(--verde); color: #fff; text-decoration: none; transition: background .2s;
      }
      .btn:hover { background: var(--verde2); }
      .btn.ghost { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,.7); }
      header.site {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 24px; position: sticky; top: 0; background: rgba(246,241,232,.9);
        backdrop-filter: blur(10px); border-bottom: 1px solid var(--linea); z-index: 20;
      }
      .brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
      .brand svg { color: var(--tinta); }
      .brand b { font-family: var(--serif); font-weight: 400; font-size: 24px; letter-spacing: .22em; color: var(--tinta); line-height: 1; }
      .brand small { color: var(--gris); font-size: 10px; letter-spacing: .28em; text-transform: uppercase; white-space: nowrap; }
      footer.site { background: var(--tinta); color: #cfc9bc; margin-top: 60px; padding: 46px 0; font-family: var(--sans); font-size: 14px; }
      footer.site a { color: #fff; }
      /* Selector de idioma (menú desplegable sin JS, con <details>) */
      .langsel { position: relative; }
      .langsel > summary {
        list-style: none; cursor: pointer; display: flex; align-items: center; gap: 6px;
        font-size: 13px; color: var(--tinta); padding: 7px 10px; border: 1px solid var(--linea);
        border-radius: 20px; background: rgba(255,255,255,.5); user-select: none;
      }
      .langsel > summary::-webkit-details-marker { display: none; }
      .langsel > summary .chev { transition: transform .2s; opacity: .6; }
      .langsel[open] > summary .chev { transform: rotate(180deg); }
      .langsel .langmenu {
        position: absolute; right: 0; top: calc(100% + 8px); z-index: 40;
        background: #fff; border: 1px solid var(--linea); border-radius: 12px;
        box-shadow: 0 14px 40px rgba(0,0,0,.16); padding: 6px; min-width: 190px;
        max-height: 70vh; overflow: auto;
      }
      .langsel .langmenu a {
        display: flex; align-items: center; gap: 10px; padding: 9px 12px; border-radius: 8px;
        text-decoration: none; color: var(--tinta); font-size: 14px;
      }
      .langsel .langmenu a:hover { background: var(--arena); }
      .langsel .langmenu a.on { font-weight: 600; color: var(--verde); }
      .langsel .langmenu a .flag { font-size: 17px; line-height: 1; }
      /* Navegación de cabecera */
      .site-nav { display: flex; gap: 18px; align-items: center; }
      /* --- Responsive de la cabecera (evita el desbordamiento en móvil) --- */
      @media (max-width: 680px) {
        header.site { padding: 11px 14px; gap: 10px; }
        .brand { gap: 9px; }
        .brand svg { width: 30px; height: 30px; }
        .brand b { font-size: 19px; letter-spacing: .16em; }
        .brand small { font-size: 8px; letter-spacing: .2em; }
        .site-nav { gap: 8px; }
        /* Los enlaces de ancla se ocultan en móvil: se navega con el botón y el scroll */
        .site-nav .navlink { display: none; }
        .langsel > summary { padding: 6px 9px; font-size: 12px; }
        .site-nav .btn { padding: 10px 15px; font-size: 12.5px; letter-spacing: .02em; }
      }
      @media (max-width: 380px) {
        .brand small { display: none; }
        .site-nav .btn { padding: 9px 13px; }
      }
    </style>
  </head>
  <body>
    <header class="site">
      <a class="brand" href="/">
        <!-- Marca GURAH: G + ola dentro de un círculo (según board de identidad) -->
        <svg width="38" height="38" viewBox="0 0 48 48" aria-hidden="true" fill="none">
          <circle cx="24" cy="24" r="22" stroke="currentColor" stroke-width="1.3" />
          <path d="M33 16.5 A11 11 0 1 0 34.5 31 L34.5 24 L27 24" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" />
          <path d="M14.5 27.5 q4 -4 8 0 t 8 0" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
          <path d="M15.5 31.5 q4 -3.5 8 0 t 8 0" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" opacity="0.55" />
        </svg>
        <span><b>{t.brand.name}</b><br /><small>{t.brand.subtitle}</small></span>
      </a>
      <nav class="sans site-nav">
        <a class="navlink" href="/#apartamentos" style="text-decoration:none;color:var(--tinta)">{tr(lang, 'nav.apartments')}</a>
        <a class="navlink" href="/#entorno" style="text-decoration:none;color:var(--tinta)">{tr(lang, 'nav.environment')}</a>
        <details class="langsel">
          <summary aria-label={tr(lang, 'lang.label')}>
            {activeLocale.code === 'eu' ? <span class="flag" set:html={ikurrina} /> : <span class="flag">{activeLocale.flag}</span>}
            <span>{activeLocale.code.toUpperCase()}</span>
            <svg class="chev" width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="langmenu">
            {LOCALES.map((l) => (
              <a href={langHref(Astro.url, l.code)} class={l.code === lang ? 'on' : ''} hreflang={l.htmlLang} lang={l.htmlLang}>
                {l.code === 'eu' ? <span class="flag" set:html={ikurrina} /> : <span class="flag">{l.flag}</span>}<span>{l.endonym}</span>
              </a>
            ))}
          </div>
        </details>
        <a class="btn" href="/#apartamentos">{tr(lang, 'nav.book')}</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site">
      <div class="container" style="display:flex;flex-wrap:wrap;gap:30px;justify-content:space-between">
        <div>
          <b class="serif" style="font-size:22px;letter-spacing:.22em">{t.brand.name}</b>
          <p style="letter-spacing:.18em;font-size:11px;text-transform:uppercase;color:#a49d8f;margin:4px 0 10px">{t.brand.tagline}</p>
          <p>{tr(lang, 'footer.boutique')}<br />{tr(lang, 'footer.near')}</p>
        </div>
        <div>
          <p><strong>{tr(lang, 'footer.directTitle')}</strong><br />{tr(lang, 'footer.directDesc')}</p>
          <p class="muted" style="color:#9fb0a8">{tr(lang, 'footer.venmon')}</p>
        </div>
        <div>
          <a href="/privacidad">{tr(lang, 'footer.privacy')}</a> · <a href="/panel/login">{tr(lang, 'footer.panel')}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
