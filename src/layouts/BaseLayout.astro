---
/**
 * BaseLayout.astro — Shell común GURAH (branding, tipografía, tokens de color).
 * Colores/logo: [PENDIENTE CLIENTE] — placeholders coherentes con "rural boutique 5*".
 */
export interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const {
  title = 'GURAH Boutique Apartments · Bakio, Bizkaia',
  description = 'Apartamentos boutique en Bakio, a 3 km de San Juan de Gaztelugatxe. Piscina, pet-friendly, reserva directa con el mejor precio.',
  lang = 'es',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <style is:global>
      :root {
        --verde: #0e5c4a;
        --verde2: #127a63;
        --arena: #f4efe6;
        --crema: #fbf8f2;
        --tinta: #1a2420;
        --gris: #6b7a74;
        --linea: #e3ddd0;
        --dorado: #c9a24b;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: 'Georgia', 'Times New Roman', serif;
        color: var(--tinta);
        background: var(--crema);
        line-height: 1.55;
      }
      h1, h2, h3, .sans { font-family: system-ui, -apple-system, 'Segoe UI', sans-serif; }
      a { color: var(--verde); }
      .container { max-width: 1120px; margin: 0 auto; padding: 0 20px; }
      .btn {
        display: inline-block; border: 0; border-radius: 10px; cursor: pointer;
        padding: 12px 22px; font-size: 15px; font-weight: 600; font-family: system-ui, sans-serif;
        background: var(--verde); color: #fff; text-decoration: none;
      }
      .btn:hover { background: var(--verde2); }
      .btn.ghost { background: transparent; color: var(--verde); border: 1px solid var(--verde); }
      header.site {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; position: sticky; top: 0; background: rgba(251,248,242,.92);
        backdrop-filter: blur(8px); border-bottom: 1px solid var(--linea); z-index: 20;
      }
      .brand { display: flex; align-items: center; gap: 10px; font-family: system-ui, sans-serif; }
      .brand b { font-size: 22px; letter-spacing: .18em; color: var(--verde); }
      .brand small { color: var(--gris); font-size: 11px; letter-spacing: .12em; text-transform: uppercase; }
      footer.site { background: var(--tinta); color: #d7ded9; margin-top: 60px; padding: 40px 0; font-family: system-ui, sans-serif; font-size: 14px; }
      footer.site a { color: #fff; }
    </style>
  </head>
  <body>
    <header class="site">
      <a class="brand" href="/" style="text-decoration:none">
        <!-- Logo placeholder [PENDIENTE CLIENTE] -->
        <svg width="30" height="30" viewBox="0 0 40 40" aria-hidden="true"><circle cx="20" cy="20" r="19" fill="none" stroke="#0e5c4a" stroke-width="2"/><path d="M12 26V16l8-6 8 6v10" fill="none" stroke="#0e5c4a" stroke-width="2"/><path d="M12 20h16" stroke="#c9a24b" stroke-width="2"/></svg>
        <span><b>GURAH</b><br /><small>Boutique Apartments · Bakio</small></span>
      </a>
      <nav class="sans" style="display:flex;gap:18px;align-items:center">
        <a href="/#apartamentos" style="text-decoration:none;color:var(--tinta)">Apartamentos</a>
        <a href="/#experiencia" style="text-decoration:none;color:var(--tinta)">Entorno</a>
        <a class="btn" href="/#apartamentos">Reservar</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site">
      <div class="container" style="display:flex;flex-wrap:wrap;gap:30px;justify-content:space-between">
        <div>
          <b style="font-size:18px;letter-spacing:.18em">GURAH</b>
          <p>Apartamentos boutique · Bakio, Bizkaia<br />A 3 km de San Juan de Gaztelugatxe.</p>
        </div>
        <div>
          <p><strong>Reserva directa</strong><br />El mejor precio, sin comisiones de plataformas.</p>
          <p class="muted" style="color:#9fb0a8">Un proyecto de Venmon.</p>
        </div>
        <div>
          <a href="/privacidad">Privacidad</a> · <a href="/panel/login">Panel</a>
        </div>
      </div>
    </footer>
  </body>
</html>
