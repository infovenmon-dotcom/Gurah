---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getActiveApartments } from '../lib/apartmentsStore';
import { getBlockedDates } from '../lib/bookings';
import { webPrice } from '../lib/pricing';
import { isDemoMode } from '../lib/persist';
import { getTheme } from '../lib/theme';
import { getLang, t as tr, tx, servicioLabelI18n, localizeApartment } from '../lib/i18n';

const theme = getTheme(Astro.url);
const t = theme; // alias para el resto del markup
const lang = getLang(Astro.url, Astro.cookies, Astro.request.headers.get('accept-language'));
const servicioLabel = (key: string) => servicioLabelI18n(key, lang);

const apartments = (await getActiveApartments()).map((a) => localizeApartment(a as any, lang));
const demo = await isDemoMode();

// Puntuación real de Booking por unidad (Lurra y Zerua comparten el listado de la casa).
const BOOKING_APT: Record<string, { s: string; o: number }> = {
  lurra: { s: '9,7', o: 124 }, zerua: { s: '9,7', o: 124 }, bakea: { s: '9,5', o: 76 },
};
// Foto real de portada por unidad (interior de cada apartamento de la casa).
const APT_PHOTO: Record<string, string> = {
  lurra: '/img/gurah/lurra-salon.jpg', zerua: '/img/gurah/zerua-salon.jpg',
};

// Inyección para el motor de reserva en cliente (precio web + bloqueos).
const avail = await Promise.all(
  apartments.map(async (a) => ({
    id: a.id, nombre: a.nombre, concepto: a.concepto, storytelling: a.storytelling,
    ubicacion: a.ubicacion, m2: a.m2, dormitorios: a.dormitorios, banos: a.banos,
    capacidad: a.capacidad, camas: a.camas, servicios: a.servicios,
    precio_base: a.precio_base, precio_base_web: webPrice(a.precio_base),
    estancia_minima: a.estancia_minima, fotos: a.fotos, clip: a.clip,
    blocked: await getBlockedDates(a.id),
  })),
);

// Cadenas para el motor cliente (home.js) según idioma.
const I18N = {
  minStay: tr(lang, 'js.minStay'),
  nights: tr(lang, 'js.nights'),
  notAvailable: tr(lang, 'js.notAvailable'),
  saveBefore: tr(lang, 'js.saveBefore'),
  saveAfter: tr(lang, 'js.saveAfter'),
  completeDates: tr(lang, 'js.completeDates'),
  processing: tr(lang, 'js.processing'),
  bookPay: tr(lang, 'modal.book'),
  couldNotComplete: tr(lang, 'js.couldNotComplete'),
  netError: tr(lang, 'js.netError'),
  typing: tr(lang, 'js.typing'),
  ccError: tr(lang, 'js.ccError'),
  connError: tr(lang, 'js.connError'),
  lang,
};
---

<BaseLayout lang={lang}>
  {demo && (
    <div class="sans demo-bar">{tr(lang, 'demo.bar')}</div>
  )}

  <!-- ===================== HERO CINEMATOGRÁFICO ===================== -->
  <section class="hero">
    {t.hero.videoUrl ? (
      <video class="hero-media" autoplay muted loop playsinline poster={t.hero.images[0]}>
        <source src={t.hero.videoUrl} type="video/mp4" />
      </video>
    ) : (
      <div class="hero-slides" aria-hidden="true">
        {t.hero.images.map((src, i) => (
          <div class="hero-slide" style={`background-image:url('${src}');animation-delay:${i * 5}s`} />
        ))}
      </div>
    )}
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-inner reveal in">
      <p class="hero-eyebrow sans">{tx(lang, 'hero.eyebrow', t.hero.eyebrow)}</p>
      <h1 class="hero-title">{tx(lang, 'hero.title0', t.hero.titleLines[0])}<br /><em>{tx(lang, 'hero.title1', t.hero.titleLines[1])}</em></h1>
      <p class="hero-tagline sans"><span></span>{t.brand.tagline}<span></span></p>
      <a class="btn hero-cta" href="#historia">{tx(lang, 'hero.cta', t.hero.ctaLabel)}</a>
    </div>
    <a href="#historia" class="hero-scroll sans" aria-label={tr(lang, 'story.discover')}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M6 13l6 6 6-6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
  </section>

  <!-- ===================== STORYTELLING ===================== -->
  <section id="historia" class="story">
    <div class="story-text reveal">
      <h2 class="story-title">{tx(lang, 'story.title', t.storytelling.title).split('\n').map((l) => (<span>{l}<br /></span>))}</h2>
      {t.storytelling.paragraphs.map((p, i) => (<p class="sans">{tx(lang, 'story.p' + i, p)}</p>))}
      <p class="story-host sans">♡ {tr(lang, 'story.host')}</p>
      <a class="link-underline sans" href="#apartamentos">{tr(lang, 'story.discover')}</a>
    </div>
    <div class="story-img reveal" style={`background-image:url('${t.storytelling.image}')`}></div>
  </section>

  <!-- ===================== APARTAMENTOS (pantalla completa) ===================== -->
  <section id="apartamentos" class="section-head reveal">
    <p class="kicker sans">{tr(lang, 'apts.kicker')}</p>
    <h2>{tr(lang, 'apts.title')}</h2>
    <p class="sans muted-lead">{tr(lang, 'apts.lead', { n: apartments.length })}</p>
  </section>

  {avail.map((a, i) => (
    <section class={`apt-full ${i % 2 === 1 ? 'rev' : ''}`}>
      <div class="apt-full-img reveal" style={`background-image:url('${APT_PHOTO[a.id] || (a.fotos && a.fotos[0] && String(a.fotos[0]).startsWith('/img/') ? a.fotos[0] : '/img/placeholder/apt-' + (a.ubicacion.tipo === 'playa' ? 'playa' : 'campo') + '.svg')}')`}>
        <span class="apt-loc sans">{a.ubicacion.tipo === 'playa' ? '🏖 ' + tr(lang, 'loc.beach') : '🌳 ' + tr(lang, 'loc.field')} · {a.ubicacion.texto.replace(/^(campo|playa)\s*·\s*/i, '')}</span>
      </div>
      <div class="apt-full-text reveal">
        <p class="kicker sans">{a.concepto}</p>
        <h3>{a.nombre}</h3>
        <p class="apt-story sans">{a.storytelling.replace('[PENDIENTE CLIENTE] ', '')}</p>
        <div class="apt-specs sans">
          <span>{a.m2} m²</span><i></i><span>{a.dormitorios} {tr(lang, 'unit.bedrooms')}</span><i></i>
          <span>{a.banos} {a.banos > 1 ? tr(lang, 'unit.baths') : tr(lang, 'unit.bath')}</span><i></i><span>{tr(lang, 'unit.upto')} {a.capacidad}</span>
        </div>
        {a.camas && <p class="apt-camas sans">🛏 {a.camas}</p>}
        {BOOKING_APT[a.id] && <p class="apt-booking sans"><b>{BOOKING_APT[a.id].s}</b>/10 · {BOOKING_APT[a.id].o} opiniones en Booking.com</p>}
        <div class="apt-serv sans">{a.servicios.slice(0, 5).map((s) => (<span>{servicioLabel(s)}</span>))}</div>
        <div class="apt-foot">
          <div class="apt-price sans"><s>{Math.round(a.precio_base)} €</s><b>{Math.round(a.precio_base_web)} €</b><small>{tr(lang, 'price.perNight')}</small></div>
          <button class="btn book" data-id={a.id}>{tr(lang, 'book.cta')}</button>
        </div>
      </div>
    </section>
  ))}

  <!-- ===================== UNA EXPERIENCIA ===================== -->
  <section class="exp">
    <div class="section-head reveal"><p class="kicker sans">{tx(lang, 'exp.kicker', t.experience.kicker)}</p><h2>{tx(lang, 'exp.title', t.experience.title)}</h2></div>
    <div class="exp-grid">
      {t.experience.items.map((it, i) => (
        <figure class="exp-item reveal" style={`background-image:url('${it.foto}')`}>
          <figcaption class="serif">{tx(lang, 'exp.i' + i, it.texto)}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <!-- ===================== EL LUGAR ===================== -->
  <section id="entorno" class="place">
    <div class="section-head reveal"><p class="kicker sans">{tx(lang, 'place.kicker', t.place.kicker)}</p><h2>{tx(lang, 'place.title', t.place.title)}</h2></div>
    <div class="place-grid">
      {t.place.items.map((it, i) => (
        <article class="place-item reveal">
          <div class="place-img" style={`background-image:url('${it.foto}')`}></div>
          <h3>{tx(lang, 'place.i' + i + '.t', it.titulo)}</h3>
          <p class="sans">{tx(lang, 'place.i' + i + '.d', it.texto)}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ===================== GALERÍA EDITORIAL ===================== -->
  <section class="gallery">
    <div class="section-head reveal"><p class="kicker sans">{tx(lang, 'gallery.kicker', t.gallery.kicker)}</p><h2>{tx(lang, 'gallery.title', t.gallery.title)}</h2></div>
    <div class="gal-mosaic">
      {t.gallery.images.map((src, i) => (
        <figure class={`gal-cell g${i % 8} reveal`} style={`background-image:url('${src}')`}></figure>
      ))}
    </div>
  </section>

  <!-- ===================== OPINIONES ===================== -->
  <section class="reviews">
    <div class="section-head reveal"><p class="kicker sans">{tr(lang, 'reviews.kicker')}</p><h2>{tr(lang, 'reviews.title')}</h2><p class="sans muted-lead">{tr(lang, 'reviews.lead')}</p></div>
    <div class="booking-panel reveal">
      <div class="bp-card">
        <div class="bp-head">
          <span class="bp-badge serif">{t.booking.score}<small>/10</small></span>
          <span class="bp-label sans">{t.booking.etiqueta}</span>
          <span class="bp-count sans">{t.booking.opiniones} opiniones · Booking.com</span>
        </div>
        <div class="bp-cats">
          {t.booking.categorias.map((c) => (
            <div class="bp-cat">
              <span class="bp-cat-top sans"><span>{c.nombre}</span><b>{c.valor.toFixed(1).replace('.', ',')}</b></span>
              <span class="bp-bar"><i style={`width:${c.valor * 10}%`}></i></span>
            </div>
          ))}
        </div>
      </div>
      {t.booking.otros.length > 0 && (
        <p class="bp-otros sans">{t.booking.otros.map((o) => `${o.nombre}: ${o.score} · ${o.opiniones} opiniones`).join('   ·   ')}</p>
      )}
    </div>
    <div class="reviews-list">
      {t.reviews.map((r) => (
        <blockquote class="review reveal">
          <span class="rev-stars">★★★★★</span>
          <p class="serif">“{r.texto}”</p>
          <cite class="sans">— {r.autor}{r.origen ? ` · ${r.origen}` : ''}</cite>
        </blockquote>
      ))}
    </div>
  </section>

  <!-- ===================== RESERVA FINAL ===================== -->
  <section class="cta-final reveal">
    <h2>{tr(lang, 'cta.title')}</h2>
    <p class="sans">{tr(lang, 'cta.desc')}</p>
    <a class="btn" href="#apartamentos">{tr(lang, 'cta.btn')}</a>
  </section>

  <!-- ===================== MODAL DE RESERVA ===================== -->
  <div id="modal" class="modal" style="display:none">
    <div class="modal-box sans">
      <div class="modal-top"><h3 id="m-title"></h3><button id="m-close" aria-label={tr(lang, 'modal.close')}>×</button></div>
      <p id="m-sub" class="muted"></p>
      <div class="modal-row">
        <label>{tr(lang, 'modal.checkin')}<input id="m-in" type="date" /></label>
        <label>{tr(lang, 'modal.checkout')}<input id="m-out" type="date" /></label>
      </div>
      <label class="block">{tr(lang, 'modal.guests')}<input id="m-pax" type="number" min="1" value="2" /></label>
      <div id="m-quote" class="modal-quote" style="display:none"></div>
      <div id="m-msg" class="modal-msg"></div>
      <hr />
      <div class="modal-row"><input id="m-nombre" placeholder={tr(lang, 'modal.name')} /><input id="m-email" type="email" placeholder={tr(lang, 'modal.email')} /></div>
      <input id="m-tel" class="block" placeholder={tr(lang, 'modal.phone')} />
      <button id="m-book" class="btn full">{tr(lang, 'modal.book')}</button>
      <p class="fineprint">{tr(lang, 'modal.fineprint')}</p>
    </div>
  </div>

  <!-- ===================== CONCIERGE IA ===================== -->
  <button id="cc-launch" class="cc-launch sans" aria-label={tx(lang, 'concierge.launcher', t.concierge.launcher)}>
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 5h16v11H8l-4 4V5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
    <span>{tx(lang, 'concierge.launcher', t.concierge.launcher)}</span>
  </button>
  <div id="cc-panel" class="cc-panel sans" style="display:none">
    <div class="cc-head"><b class="serif">{tr(lang, 'cc.title', { brand: t.brand.name })}</b><button id="cc-close" aria-label={tr(lang, 'modal.close')}>×</button></div>
    <div id="cc-log" class="cc-log"></div>
    <form id="cc-form" class="cc-form"><input id="cc-input" placeholder={tr(lang, 'cc.placeholder')} autocomplete="off" /><button type="submit" aria-label="→">→</button></form>
  </div>

  <script is:inline set:html={`window.GURAH_AVAIL = ${JSON.stringify(avail)}; window.CC_GREETING = ${JSON.stringify(tx(lang, 'concierge.greeting', t.concierge.greeting))}; window.I18N = ${JSON.stringify(I18N)};`}></script>
  <script is:inline src="/js/home.js"></script>

  <style>
    .demo-bar { background:#e8dcae; color:#5b4a00; text-align:center; padding:7px; font-size:12px; letter-spacing:.06em; }
    .reveal { opacity:0; transform:translateY(24px); transition:opacity .9s ease, transform .9s ease; }
    .reveal.in { opacity:1; transform:none; }
    .kicker { letter-spacing:.28em; text-transform:uppercase; font-size:11px; color:var(--dorado); margin:0 0 12px; font-weight:500; }
    .section-head { max-width:1120px; margin:0 auto; padding:100px 24px 30px; text-align:center; }
    .section-head h2 { font-size:clamp(30px,5vw,50px); margin:0; }
    .muted-lead { color:var(--gris); margin-top:12px; }

    /* HERO */
    .hero { position:relative; height:100vh; min-height:620px; display:flex; align-items:center; justify-content:center; text-align:center; color:#fff; overflow:hidden; }
    .hero-media { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
    .hero-slides { position:absolute; inset:0; }
    .hero-slide { position:absolute; inset:0; background-size:cover; background-position:center; opacity:0;
      animation:heroCross 15s linear infinite; }
    @keyframes heroCross {
      0% { opacity:0; transform:scale(1.06); }
      6% { opacity:1; } 28% { opacity:1; } 34% { opacity:0; }
      100% { opacity:0; transform:scale(1.12); }
    }
    .hero-overlay { position:absolute; inset:0; background:linear-gradient(180deg, rgba(35,34,30,.36) 0%, rgba(35,34,30,.14) 40%, rgba(35,34,30,.6) 100%); }
    .hero-inner { position:relative; z-index:2; max-width:860px; padding:40px 24px; }
    .hero-eyebrow { letter-spacing:.36em; text-transform:uppercase; font-size:12px; opacity:.92; margin:0 0 22px; }
    .hero-title { font-weight:400; font-size:clamp(44px,9vw,104px); line-height:1.0; margin:0 0 20px; text-shadow:0 2px 46px rgba(0,0,0,.3); }
    .hero-title em { font-style:italic; color:#e6d4ac; }
    .hero-tagline { display:flex; align-items:center; justify-content:center; gap:14px; letter-spacing:.34em; text-transform:uppercase; font-size:12px; opacity:.9; margin:0 0 34px; }
    .hero-tagline span { width:36px; height:1px; background:rgba(230,212,172,.7); }
    .hero-cta { background:#fff; color:var(--tinta); padding:15px 34px; }
    .hero-cta:hover { background:#f0e9db; }
    .hero-scroll { position:absolute; bottom:28px; left:50%; transform:translateX(-50%); z-index:2; color:#fff; opacity:.85; }
    .hero-scroll svg { animation:bob 1.9s ease-in-out infinite; }
    @keyframes bob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(7px)} }

    /* STORYTELLING */
    .story { max-width:1180px; margin:0 auto; padding:110px 24px; display:grid; grid-template-columns:1.05fr .95fr; gap:64px; align-items:center; }
    .story-title { font-size:clamp(30px,4.6vw,54px); line-height:1.08; margin:0 0 26px; }
    .story-text p.sans { color:#5c574c; font-size:17px; line-height:1.85; margin:0 0 18px; max-width:38ch; }
    .story-text p.story-host { color:var(--dorado); font-size:14px; letter-spacing:.03em; margin:4px 0 22px; }
    .link-underline { color:var(--verde); text-decoration:none; border-bottom:1px solid var(--verde); padding-bottom:2px; font-size:14px; letter-spacing:.02em; }
    .story-img { min-height:480px; border-radius:6px; background-size:cover; background-position:center; }

    /* APARTAMENTOS full */
    .apt-full { display:grid; grid-template-columns:1.15fr 1fr; min-height:82vh; align-items:stretch; }
    .apt-full.rev { grid-template-columns:1fr 1.15fr; }
    .apt-full.rev .apt-full-img { order:2; }
    .apt-full.rev .apt-full-text { order:1; }
    .apt-full-img { position:relative; background-size:cover; background-position:center; min-height:56vh; overflow:hidden; }
    .apt-video { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:0; }
    .apt-loc { position:absolute; top:20px; left:20px; z-index:2; background:rgba(35,34,30,.6); color:#fff; padding:6px 13px; border-radius:20px; font-size:12px; letter-spacing:.04em; }
    .apt-full-text { display:flex; flex-direction:column; justify-content:center; padding:6vh 6vw; background:var(--crema); }
    .apt-full.rev .apt-full-text { background:var(--arena); }
    .apt-full-text h3 { font-size:clamp(30px,4vw,46px); margin:0 0 18px; }
    .apt-story { color:#5c574c; font-size:16px; line-height:1.8; max-width:44ch; margin:0 0 22px; }
    .apt-specs { display:flex; align-items:center; gap:14px; color:var(--gris); font-size:14px; margin-bottom:18px; }
    .apt-specs i { width:4px; height:4px; border-radius:50%; background:var(--dorado); display:inline-block; }
    .apt-camas { color:var(--gris); font-size:13px; margin:0 0 18px; }
    .apt-serv { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:30px; }
    .apt-serv span { border:1px solid var(--linea); border-radius:20px; padding:5px 13px; font-size:12px; color:#6b665b; }
    .apt-foot { display:flex; align-items:center; justify-content:space-between; gap:20px; flex-wrap:wrap; }
    .apt-price { display:flex; align-items:baseline; gap:8px; }
    .apt-price s { color:var(--gris); font-size:15px; }
    .apt-price b { font-family:var(--serif); color:var(--verde); font-size:30px; }
    .apt-price small { color:var(--gris); font-size:13px; }

    /* EXPERIENCIA */
    .exp { background:var(--tinta); color:#f2ede2; padding:20px 0 90px; margin-top:40px; }
    .exp .kicker { color:var(--dorado); }
    .exp .section-head h2 { color:#f6f1e8; }
    .exp-grid { max-width:1200px; margin:0 auto; padding:0 24px; display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }
    .exp-item { position:relative; height:360px; border-radius:6px; overflow:hidden; background-size:cover; background-position:center; display:flex; align-items:flex-end; }
    .exp-item::after { content:""; position:absolute; inset:0; background:linear-gradient(180deg,rgba(20,19,16,0) 40%,rgba(20,19,16,.72) 100%); }
    .exp-item figcaption { position:relative; z-index:2; color:#fff; padding:22px; font-size:22px; line-height:1.25; }

    /* EL LUGAR */
    .place { padding-bottom:90px; }
    .place-grid { max-width:1180px; margin:0 auto; padding:0 24px; display:grid; grid-template-columns:repeat(3,1fr); gap:30px; }
    .place-img { height:300px; border-radius:6px; background-size:cover; background-position:center; margin-bottom:18px; }
    .place-item h3 { font-size:24px; margin:0 0 6px; }
    .place-item p { color:var(--gris); font-size:15px; margin:0; }

    /* GALERÍA EDITORIAL (mosaico asimétrico tipo revista) */
    .gallery { padding-bottom:100px; }
    .gal-mosaic { max-width:1180px; margin:0 auto; padding:0 24px; display:grid; grid-template-columns:repeat(4,1fr); grid-auto-rows:190px; gap:12px; }
    .gal-cell { margin:0; background-size:cover; background-position:center; border-radius:6px; transition:opacity .9s ease, transform .9s ease, filter .6s ease; }
    .gal-cell:hover { filter:brightness(1.05) saturate(1.05); }
    .gal-cell.g0 { grid-column:span 2; grid-row:span 2; }
    .gal-cell.g3 { grid-column:span 2; }
    .gal-cell.g5 { grid-row:span 2; }
    .gal-cell.g7 { grid-column:span 2; }
    /* stagger suave del reveal en la galería */
    .gal-cell.reveal { transition-delay:.05s; }
    .gal-cell:nth-child(2n).reveal { transition-delay:.12s; }
    .gal-cell:nth-child(3n).reveal { transition-delay:.2s; }

    /* OPINIONES */
    .reviews { background:var(--arena); padding-bottom:100px; }
    .booking-panel { max-width:920px; margin:0 auto 44px; padding:0 24px; }
    .bp-card { background:#fff; border:1px solid var(--linea); border-radius:18px; padding:26px; display:grid; grid-template-columns:auto 1fr; gap:34px; align-items:center; }
    .bp-head { text-align:center; }
    .bp-badge { display:inline-block; background:#003b95; color:#fff; font-size:34px; line-height:1; padding:12px 16px; border-radius:10px 10px 10px 0; }
    .bp-badge small { font-size:15px; opacity:.85; }
    .bp-label { display:block; font-weight:600; margin-top:12px; color:var(--tinta); }
    .bp-count { display:block; color:var(--gris); font-size:12px; margin-top:2px; }
    .bp-cats { display:grid; grid-template-columns:1fr 1fr; gap:13px 30px; }
    .bp-cat-top { display:flex; justify-content:space-between; font-size:13px; color:#4b5a53; margin-bottom:5px; }
    .bp-cat-top b { color:var(--verde); }
    .bp-bar { display:block; height:5px; background:var(--linea); border-radius:3px; overflow:hidden; }
    .bp-bar i { display:block; height:100%; background:var(--verde); border-radius:3px; }
    .bp-otros { text-align:center; color:var(--gris); font-size:13px; margin:14px 0 0; }
    .apt-booking { color:#003b95; font-size:13px; margin:0 0 18px; }
    .apt-booking b { font-size:15px; }
    .reviews-list { max-width:1080px; margin:0 auto; padding:0 24px; display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:34px; }
    .review { margin:0; }
    .rev-stars { color:var(--dorado); letter-spacing:2px; font-size:13px; display:block; margin-bottom:10px; }
    .review p { font-size:19px; line-height:1.5; font-style:italic; color:var(--tinta); margin:0 0 14px; }
    .review cite { color:var(--gris); font-style:normal; font-size:13px; letter-spacing:.04em; }

    /* CTA FINAL */
    .cta-final { text-align:center; padding:110px 24px; }
    .cta-final h2 { font-size:clamp(32px,5vw,54px); margin:0 0 14px; }
    .cta-final p { color:var(--gris); margin:0 0 28px; }

    /* MODAL */
    .modal { position:fixed; inset:0; background:rgba(20,19,16,.55); z-index:60; display:flex; align-items:center; justify-content:center; padding:16px; }
    .modal-box { background:var(--crema); max-width:460px; width:100%; border-radius:14px; padding:26px; max-height:92vh; overflow:auto; }
    .modal-top { display:flex; justify-content:space-between; align-items:flex-start; }
    .modal-top h3 { margin:0; font-size:24px; }
    .modal-top button { border:0; background:none; font-size:26px; cursor:pointer; color:var(--gris); line-height:1; }
    .modal .muted { color:var(--gris); font-size:14px; margin:4px 0 16px; }
    .modal-row { display:flex; gap:10px; }
    .modal label { flex:1; font-size:12px; color:var(--gris); display:block; }
    .modal input { width:100%; padding:10px; border:1px solid var(--linea); border-radius:8px; margin-top:4px; font-size:14px; background:#fff; font-family:var(--sans); }
    .modal .block { display:block; margin-top:10px; }
    .modal-quote { margin:14px 0; padding:13px; background:var(--arena); border-radius:9px; font-size:14px; }
    .modal-msg { color:#b4462f; font-size:13px; min-height:18px; }
    .modal hr { border:0; border-top:1px solid var(--linea); margin:14px 0; }
    .btn.full { width:100%; margin-top:16px; }
    .fineprint { font-size:12px; color:var(--gris); text-align:center; margin:10px 0 0; }

    /* CONCIERGE */
    .cc-launch { position:fixed; bottom:22px; right:22px; z-index:55; display:flex; align-items:center; gap:8px; background:var(--tinta); color:#fff; border:0; border-radius:30px; padding:12px 18px; cursor:pointer; font-size:14px; letter-spacing:.03em; box-shadow:0 8px 30px rgba(0,0,0,.25); }
    .cc-panel { position:fixed; bottom:22px; right:22px; z-index:56; width:min(380px,92vw); height:min(560px,80vh); background:var(--crema); border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,.3); display:flex; flex-direction:column; overflow:hidden; }
    .cc-head { display:flex; justify-content:space-between; align-items:center; padding:16px 18px; background:var(--tinta); color:#fff; }
    .cc-head b { font-size:16px; letter-spacing:.06em; }
    .cc-head button { border:0; background:none; color:#fff; font-size:22px; cursor:pointer; }
    .cc-log { flex:1; overflow:auto; padding:16px; display:flex; flex-direction:column; gap:10px; }
    .cc-msg { max-width:85%; padding:10px 13px; border-radius:14px; font-size:14px; line-height:1.5; }
    .cc-msg.bot { background:#fff; border:1px solid var(--linea); align-self:flex-start; border-bottom-left-radius:4px; }
    .cc-msg.me { background:var(--verde); color:#fff; align-self:flex-end; border-bottom-right-radius:4px; }
    .cc-msg.typing { color:var(--gris); font-style:italic; }
    .cc-form { display:flex; gap:8px; padding:12px; border-top:1px solid var(--linea); }
    .cc-form input { flex:1; padding:11px 14px; border:1px solid var(--linea); border-radius:22px; font-size:14px; font-family:var(--sans); }
    .cc-form button { border:0; background:var(--verde); color:#fff; width:42px; border-radius:50%; cursor:pointer; font-size:18px; }

    @media (max-width:820px) {
      .story { grid-template-columns:1fr; gap:36px; }
      .story-img { min-height:320px; }
      .apt-full, .apt-full.rev { grid-template-columns:1fr; }
      .apt-full.rev .apt-full-img { order:1; } .apt-full.rev .apt-full-text { order:2; }
      .exp-grid { grid-template-columns:repeat(2,1fr); }
      .place-grid { grid-template-columns:1fr; }
      .cc-launch span { display:none; }
    }
    @media (max-width:560px) {
      /* "Una experiencia" a una columna: los títulos ya no se cortan */
      .exp-grid { grid-template-columns:1fr; gap:12px; }
      .exp-item { height:260px; }
      .exp-item figcaption { font-size:24px; }
      .bp-card { grid-template-columns:1fr; gap:18px; text-align:center; }
      .bp-cats { grid-template-columns:1fr; }
      .bp-cat-top { justify-content:space-between; }
    }
    @media (prefers-reduced-motion: reduce) { .hero-slide,.hero-scroll svg { animation:none; } .hero-slide:first-child{opacity:1} .reveal{transition:none;opacity:1;transform:none} }
  </style>
</BaseLayout>
